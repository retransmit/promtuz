# Copy to `secrets.properties` (gitignored) and fill in your values.
#
# Injected into BuildConfig.RESOLVER_SEEDS at build time so infra endpoints
# stay out of this OSS repo. Format per seed: <IPK_HEX>::<host[:port]>
# The port is optional and defaults to 40433 (the resolver port) in libcore.
# A DNS name is fine — it's resolved at dial time, so a moved box only needs
# a DNS repoint, not a rebuild. Multiple seeds: separate with \n.
RESOLVER_SEEDS=<RESOLVER_IPK_HEX>::resolver.example.dev
